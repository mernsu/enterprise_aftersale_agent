# App
APP_NAME=Enterprise Customer Service Agent
RUNTIME_ENV=local
LOG_LEVEL=INFO
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM: any OpenAI-compatible chat API.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# Embedding: openai_compatible or ollama.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=60

# Database: MySQL async driver.
DATABASE_URL=mysql+aiomysql://customer_service:customer_service@127.0.0.1:3306/customer_service?charset=utf8mb4

# Redis semantic cache.
SEMANTIC_CACHE_ENABLED=false
REDIS_URL=redis://127.0.0.1:6380/0
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.90

# Qdrant knowledge base.
RAG_ENABLED=true
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=customer_service_knowledge
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35

# External web search tool.
SERPAPI_KEY=
SEARCH_RESULT_COUNT=5

# Auth.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
